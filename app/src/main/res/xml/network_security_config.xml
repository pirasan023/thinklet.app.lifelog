<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        Macのスクリーンショットサーバー（Flask/HTTP）へのアクセスを許可するために
        cleartext通信を許可する。ローカルネットワーク/Tailscale経由のためHTTPS不可。
    -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
